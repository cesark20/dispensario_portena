<div class="container-fluid px-4">
  <h1 class="mt-4">Insumos</h1>

  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de stock para reponer</h6>
    </div>

    <div class="card-body">
      <%= form_with url: reorder_summary_items_path(format: :html),
                    method: :post,
                    data: { turbo: false } do %>
        <div class="table-responsive">
          <table id="generalTable" class="table table-striped table-bordered">
            <thead class="table-dark">
              <tr>
                <th>Seleccionar</th>
                <th>Insumo</th>
                <th>Stock actual</th>
                <th>Stock mínimo</th>
                <th>Proveedor</th>
              </tr>
            </thead>
            <tbody>
              <% @items.each do |item| %>
                <tr class="<%= 'table-warning' if item.low_stock? %>">
                  <td class="text-center">
                    <%= check_box_tag "item_ids[]", item.id %>
                  </td>
                  <td><%= item.name %></td>
                  <td><%= item.total_on_hand %></td>
                  <td><%= item.min_stock %></td>
                  <td><%= item.provider&.name || 'Sin proveedor' %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="mt-3">
          <%= submit_tag "Continuar", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>