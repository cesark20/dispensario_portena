<div class="container-fluid px-4">
  <h1 class="mt-4">Insumos</h1>

  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Insumos</h6>
      <%= link_to "Nuevo Insumo", new_item_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>

    <div class="card-body">
      <div class="table-responsive">
        <table id="generalTable" class="table table-striped table-bordered">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>SKU</th>
              <th>Unidad</th>
              <th>Stock</th>
              <th>Mínimo</th>
              <th>Precio venta</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @items.each do |item| %>
              <tr class="<%= 'table-warning' if item.low_stock? %>">
                <td><%= link_to item.name, item_path(item) %></td>
                <td><%= item.sku %></td>
                <td><%= item.unit %></td>
                <td><strong><%= item.total_on_hand %></strong></td>
                <td><%= item.min_stock %></td>
                <td><%= number_to_currency(item.sale_price) if item.sale_price %></td>
                <td>
                  <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_item_path(item), class: "btn btn-warning btn-sm" %>
                  <%= link_to '<i class="fa-solid fa-trash"></i>'.html_safe, item_path(item),
                      data: { turbo: false, confirm: "¿Eliminar insumo?" },
                      method: :delete, class: "btn btn-danger btn-sm ms-1" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>