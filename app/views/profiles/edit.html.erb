<div class="container-fluid px-4">
  <h1 class="mt-4">Mi Perfil</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Editar Mi Perfil</h6>
      <%= link_to "Volver", root_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <%= form_with(model: @user, url: profile_path, local: true) do |f| %>
          <div class="mb-3">
            <%= f.label :name, "Nombre" %>
            <%= f.text_field :name, class: "form-control" , readonly: true %>
          </div>

          <div class="mb-3">
            <%= f.label :email, "Email" %>
            <%= f.email_field :email, class: "form-control" , readonly: true %>
          </div>

          <hr>

          <h5>Cambiar Contraseña (opcional)</h5>

          <div class="mb-3">
            <%= f.label :password, "Nueva Contraseña" %>
            <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirmar Contraseña" %>
            <%= f.password_field :password_confirmation, class: "form-control" %>
          </div>

          <div class="text-end">
            <%= f.submit "Actualizar", class: "btn btn-primary" %>
          </div>
        <% end %>
    </div>
  </div>
</div>


