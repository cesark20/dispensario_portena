<div class="container-fluid px-4">
  <h1 class="mt-4">Presupuestos</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Presupuestos</h6>
      <%= link_to "Nuevo Presupuesto", new_budget_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="generalTable" class="table table-striped table-bordered">
                <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Client</th>
                  <th>Date</th>
                  <th>Prod/Ser Presupuestados</th>
                  <th>Total</th>
                  <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                  <% @budgets.each do |budget| %>
                    <tr>
                      <td><%= budget.id %></td>
                      <td><%= budget.user.name %></td>
                      <td><%= budget.date&.strftime("%d/%m/%Y") || "Sin fecha" %></td>
                      <td><%= budget.budget_items.count %></td>
                      <td>$<%= number_to_currency(budget.total || 0, unit: "", separator: ",", delimiter: ".") %></td>
                      <td>
                        <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_budget_path(budget), class: "btn btn-info btn-sm" %>
                        
                        <%= link_to '<i class="fa-solid fa-trash"></i>'.html_safe, budget, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>

                        <%= link_to '<i class="fa-solid fa-file-pdf"></i>'.html_safe, 
                          budget_path(budget, format: :pdf), 
                          class: "btn btn-warning btn-sm", 
                          target: "_blank" %>

                          <%= button_to '<i class="fa-solid fa-envelope"></i>'.html_safe, send_email_budget_path(budget), method: :post, class: "btn btn-warning btn-sm", form: { data: { turbo_confirm: "¿Enviar presupuesto por mail?" }, class: "btn p-0" } %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
            </table>
          </div>
        </div>
    </div>
</div>