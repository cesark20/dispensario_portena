<div class="container-fluid px-4">
  <h1 class="mt-4">Cliente</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Clientes</h6>
      <%= link_to "Nuevo Cliente", new_client_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="generalTable" class="table table-striped table-bordered">
                <thead class="table-dark">
                <tr>
                  <th>Nombre</th>
                  <th>Email</th>
                  <th>Teléfono</th>
                  <th>Dirección</th>
                  <th>CUIT/CUIL</th>
                  <th>Razón Social</th>
                  <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                  <% @clients.each do |client| %>
                    <tr>
                      <td><%= client.name %></td>
                      <td><%= client.email %></td>
                      <td><%= client.client_info&.phone || "-" %></td>
                      <td><%= client.client_info&.address || "-" %></td>
                      <td><%= client.client_info&.tax_id || "-" %></td>
                      <td><%= client.client_info&.business_name || "-" %></td>
                      <td>
                        <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_client_path(client), class: "btn btn-warning btn-sm" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
            </table>
          </div>
        </div>
    </div>
</div>