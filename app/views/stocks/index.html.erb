<div class="container-fluid px-4">
  <h1 class="mt-4">Stock</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Stocks</h6>
      <%= link_to "Nuevo Stock", new_stock_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="generalTable" class="table table-striped table-bordered">
                <thead class="table-dark">
                <tr>
                    <th>Proveedor</th>
                    <th>Nombre</th>
                    <th>Costo</th>
                    <th>Pecio</th>
                    <th>Cantidad</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                  <% @stocks.each do |stock| %>
                    <tr>
                      <td><%= stock.provider %></td>
                      <td><%= stock.name %></td>
                       <td>$<%= number_to_currency(stock.cost, unit: "", separator: ",", delimiter: ".") %></td>
                      <td>$<%= number_to_currency(stock.price, unit: "", separator: ",", delimiter: ".") %></td>
                      <td><%= stock.available_quantity %></td>
                      <td>
                        <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_stock_path(stock), class: "btn btn-warning btn-sm" %>
                        <%= link_to '<i class="fa-solid fa-trash"></i>'.html_safe, stock, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
            </table>
          </div>
        </div>
    </div>
</div>