<div class="container my-5">
  <div class="row">
    <!-- FORMULARIO DE CONTACTO -->
    <div class="col-md-6 mb-4">
      <h2 class="mb-3">📬 Escribinos</h2>
      <%= form_with url: send_contact_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= label_tag :name, "Nombre" %>
          <%= text_field_tag :name, nil, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= label_tag :email, "Email" %>
          <%= email_field_tag :email, nil, class: "form-control", required: true %>
        </div>

        <div class="mb-3">
          <%= label_tag :message, "Mensaje" %>
          <%= text_area_tag :message, nil, rows: 5, class: "form-control", required: true %>
        </div>

        <%= submit_tag "Enviar mensaje", class: "btn btn-primary" %>
      <% end %>
    </div>

    <!-- DATOS DE LA EMPRESA -->
    <div class="col-md-6">
      <h2 class="mb-3">📍 Nuestra Empresa</h2>
      <ul class="list-unstyled">
        <li><strong>🏢 Dirección:</strong> Av. Vélez Sársfield 3685, Córdoba Capital</li>
        <li><strong>📞 WhatsApp:</strong> <a href="https://wa.me/5493517615994" target="_blank">+54 9 351 761-5994</a></li>
        <li><strong>📧 Email:</strong> <a href="mailto:info@overroad.com.ar">info@overroad.com.ar</a></li>
        <li><strong>📷 Instagram:</strong> <a href="https://www.instagram.com/overroad.argentina" target="_blank">@overroad.argentina</a></li>
      </ul>

      <div class="mt-4">
        <iframe 
          src="https://www.google.com/maps?q=Av.%20V%C3%A9lez%20S%C3%A1rsfield%203685,%20C%C3%B3rdoba&output=embed"
          width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy">
        </iframe>
      </div>
    </div>
  </div>
</div>