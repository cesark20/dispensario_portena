<div class="container py-4">
  <h1 class="mb-4">Productos</h1>

    <div class="d-flex justify-content-between mb-3">
        <%= form_with url: products_path, method: :get, local: true, class: "d-flex w-100" do %>
            <%= text_field_tag :query, params[:query], placeholder: "Buscar productos...", class: "form-control me-2" %>
            <%= submit_tag "Buscar", class: "btn btn-primary me-2" %>
            <% if params[:query].present? %>
            <%= link_to "Limpiar", products_path, class: "btn btn-secondary" %>
            <% end %>
        <% end %>
    </div>

  <div class="row">
    <div class="row">
          <div class="col-md-12">
            <div class="product-grid row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">              
              <% @paginated_products.each do |product| %>
                <div class="col d-flex">
                  <div class="card shadow-sm h-100 w-100 d-flex flex-column">
                    <% if product.images.attached? %>
                      <%= image_tag product.images.first.variant(resize_to_limit: [400, 300]), class: "card-img-top", style: "object-fit: cover; height: 200px;" %>
                    <% else %>
                      <%= image_tag "default_img.jpg", class: "card-img-top", style: "object-fit: contain; height: 200px;" %>
                    <% end %>

                    <div class="card-body d-flex flex-column justify-content-between">
                      <div>
                        <p class="text-uppercase text-muted mb-1 fw-semibold"><%= product.provider %></p>
                        <h5 class="fw-bold mb-1"><%= product.name %></h5>
                        <p class="text-muted small mb-2"><%= truncate(product.description, length: 60) %></p>

                        <span class="badge bg-warning text-dark mb-2">10.5% OFF EFECTIVO</span>

                        <h5 class="fw-bold">$<%= number_with_precision(product.price, precision: 2) %></h5>
                        <!-- <p class="text-muted small">
                          en 6 cuotas SIN INTERÉS de $<%= number_with_precision(product.price / 6.0, precision: 0) %>
                        </p> -->
                      </div>

                      <div class="mt-auto pt-2">
                        <%= link_to "VER PRODUCTO", public_product_path(product), class: "btn btn-dark w-100" %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>

  </div>

  <div class="d-flex justify-content-center mt-4">
    <%= paginate @paginated_products %>
  </div>
</div>