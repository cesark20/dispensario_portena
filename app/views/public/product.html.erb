<div class="container my-5">
  <div class="row">
    <!-- Miniaturas -->
    <div class="col-md-2 d-none d-md-block">
      <% @product.images.each do |image| %>
        <div class="mb-2">
          <%= image_tag image.variant(resize_to_limit: [100, 100]), class: "img-thumbnail" %>
        </div>
      <% end %>
    </div>

    <!-- Imagen principal -->
    <div class="col-md-5">
      <% if @product.images.attached? %>
        <%= image_tag @product.images.first.variant(resize_to_limit: [600, 600]), class: "img-fluid" %>
      <% else %>
        <%= image_tag "default_img.jpg", class: "img-fluid" %>
      <% end %>
    </div>

    <!-- Información del producto -->
    <div class="col-md-5">
      <h4 class="text-uppercase text-muted"><%= @product.provider %></h4>
      <h2 class="fw-bold"><%= @product.name %></h2>
      <p class="text-muted">Código: <%= @product.code %></p>

      <h3 class="fw-bold text-danger">$ <%= number_with_precision(@product.price, precision: 2, delimiter: '.') %></h3>
      <p class="text-muted small">Precio sin impuestos nacionales: $ <%= number_with_precision(@product.price * 0.82, precision: 2) %></p>

      <span class="badge bg-warning text-dark mb-3">20% OFF TRANSFERENCIA BANCARIA</span>

      <div class="mb-3">
        <p>3 cuotas sin interés de $ <%= number_with_precision(@product.price / 3, precision: 2) %></p>
        <p>6 cuotas sin interés de $ <%= number_with_precision(@product.price / 6, precision: 2) %></p>
        <div class="d-flex gap-2">
          <%= image_tag "logo-visa-2.png", width: 40 %>
          <%= image_tag "logo-mastercard.png", width: 40 %>
          <%= image_tag "logo-american-express.png", width: 40 %>
        </div>
      </div>

      <div class="input-group mb-3" style="max-width: 150px;">
        <span class="input-group-text">Cantidad</span>
        <input type="number" value="1" class="form-control" DISABLED>
      </div>

      <div class="d-grid gap-2">
        <a href="#" class="btn btn-danger btn-lg">CONSULTAR POR ESTE PRODUCTO </a>
        <%# <a href="#" class="btn btn-outline-dark btn-lg">COMPRAR AHORA</a> %>
      </div>

      <div class="mt-4 d-flex gap-3">
        <div>
          <i class="fa fa-store"></i><br>
          <strong>Retiro en sucursal</strong><br>
          <a href="#">Ver sucursales</a>
        </div>
        <div>
          <i class="fa fa-truck"></i><br>
          <strong>Envíos a todo el país</strong><br>
          <a href="#">Calculá tu envío</a>
        </div>
      </div>
    </div>
  </div>
</div>