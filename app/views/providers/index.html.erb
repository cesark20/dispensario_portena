<div class="container-fluid px-4">
  <h1 class="mt-4">Proovedores</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Proovedores</h6>
      <%= link_to "Nuevo Proovedor", new_provider_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="generalTable" class="table table-striped table-bordered">
                <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Contacto</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>CUIT</th>
                    <th>Activo</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                <% @providers.each do |provider| %>
                    <tr>
                    <td><%= provider.name %></td>
                    <td><%= provider.contact_name %></td>
                    <td><%= provider.phone %></td>
                    <td><%= provider.email %></td>
                    <td><%= provider.cuit %></td>
                    <td><%= provider.status ? "Si" : "No" %></td>
                    <td>
                        <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_provider_path(provider), class: "btn btn-warning btn-sm" %>
                        <%= link_to '<i class="fa-solid fa-trash"></i>'.html_safe, provider, method: :delete, data: { confirm: "¿Seguro que quieres eliminar este registro?" }, class: "btn btn-danger btn-sm", "data-turbo" => false %>
                    </td>
                    </tr>
                <% end %>
                </tbody>
            </table>
          </div>
        </div>
    </div>
</div>