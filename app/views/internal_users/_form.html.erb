<%= form_with(model: @user, url: @user.new_record? ? internal_users_path : internal_user_path(@user), local: true) do |f| %>
  <div class="mb-3">
    <%= f.label :first_name, "Nombre" %>
    <%= f.text_field :first_name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :last_name, "Apellido" %>
    <%= f.text_field :last_name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :email, "Email" %>
    <%= f.email_field :email, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :phone, "Telefono" %>
    <%= f.text_field :phone, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :address, "Direccion" %>
    <%= f.text_field :address, class: "form-control", required: true %>
  </div>
  
  <div class="mb-3">
    <%= f.label :role, "Rol" %>
    <%= f.select :role,
        [["Administrador", "admin"],
         ["Farmacia", "pharmacy"],
         ["Personal de salud", "healthcare_staff"]],
        {}, class: "form-control" %>
  </div>

  <div class="d-flex justify-content-end">
    <%= f.submit "Guardar", class: "btn btn-primary" %>
  </div>
  <% end %>