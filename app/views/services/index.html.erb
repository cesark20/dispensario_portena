<div class="container-fluid px-4">
  <h1 class="mt-4">Servicios</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Servicios</h6>
      <%= link_to "Nuevo Servicio", new_service_path, class: 'btn btn-primary btn-icon-split btn-sm' %>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="generalTable" class="table table-striped table-bordered">
                <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Descripcion</th>
                    <th>Precio</th>
                    <th>Costo</th>
                    <th>Duracion (min)</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                  <% @services.each do |service| %>
                    <tr>
                      <td><%= service.name %></td>
                      <td><%= service.description %></td>
                      <td>$<%= number_to_currency(service.price, unit: "", separator: ",", delimiter: ".") %></td>
                      <td>$<%= number_to_currency(service.cost, unit: "", separator: ",", delimiter: ".") %></td>
                      <td><%= service.duration_minutes %> min</td>
                      <td>
                        <%= link_to '<i class="fa-solid fa-pen-to-square"></i>'.html_safe, edit_service_path(service), class: "btn btn-warning btn-sm" %>
                        <%= link_to '<i class="fa-solid fa-trash"></i>'.html_safe, service, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
            </table>
          </div>
        </div>
    </div>
</div>