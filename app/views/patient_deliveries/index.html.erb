

<div class="container-fluid px-4">
  <h1 class="mt-4">Pacientes</h1>
  <div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
      <h6 class="m-0 font-weight-bold text-primary">Listado de Pacientes con medicamentos entregados</h6>
    </div>

    <div class="card-body">
      <% if @patients.empty? %>
        <div class="alert alert-info">
          Todavía no hay entregas registradas a pacientes.
        </div>
      <% else %>
        <div class="table-responsive">
          <table class="table table-bordered table-striped" id="generalTable" >
            <thead class="table-dark">
              <tr>
                <th>Paciente</th>
                <th>Cantidad total de unidades entregadas</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @patients.each do |patient| %>
                <% total_qty =
                     WithdrawalLine
                       .joins(:withdrawal)
                       .where(withdrawals: { patient_id: patient.id })
                       .sum(:quantity) %>

                <tr>
                  <td><%= patient.full_name %></td>
                  <td><%= total_qty %></td>
                  <td>
                   <%= link_to '<i class="fa-solid fa-eye"></i>'.html_safe, patient_delivery_path(patient), class: "btn btn-sm btn-info" %>

                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>
</div>