<div class="card shadow-lg border-0 rounded-lg mt-5">
  <div class="card-header">
    <div class="d-flex justify-content-center mt-2">
      <%= image_tag "logo.png", alt: "Logo", class: "mb-3 img-fluid", style: "max-width: 200px;" %>
      </div>
    <h3 class="text-center font-weight-light my-2"><%= t('.sign_in') %></h3>
  </div>
  <div class="card-body">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <!-- Email -->
        <div class="form-floating mb-3">
          <%= f.email_field :email, class: "form-control", id: "inputEmail", placeholder: "Email" %>
          <label for="inputEmail">Email</label>
        </div>

        <!-- Password -->
        <div class="form-floating mb-3">
          <%= f.password_field :password, class: "form-control", id: "inputPassword", placeholder: "Password" %>
          <label for="inputPassword">Password</label>
        </div>

        <!-- Remember Me -->
        <!-- <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input", id: "inputRememberPassword" %>
          <label class="form-check-label" for="inputRememberPassword">Remember Password</label>
        </div> -->

        <!-- Submit Button -->
        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
          <%= link_to "Olvidaste la Contraseña?", new_password_path(:user), class: "small" %>
          <%= f.submit "Ingresa", class: "btn btn-primary" %>
        </div>
      <% end %>
  </div>
  <!-- <div class="card-footer text-center py-3">
      <div class="small">
        <%# <%= render "devise/shared/links" %> %>
      </div>
  </div> -->
</div>












